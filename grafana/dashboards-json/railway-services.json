{
  "uid": "railway-services",
  "title": "Railway Services Overview",
  "tags": ["railway"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU Usage (cores)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "railway_service_cpu_usage", "legendFormat": "{{service_name}}", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "grafana_prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Utilization %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "railway_service_cpu_utilization * 100", "legendFormat": "{{service_name}}", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "grafana_prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Memory Usage (GB)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "railway_service_memory_usage_gb", "legendFormat": "{{service_name}}", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "grafana_prometheus" },
      "fieldConfig": { "defaults": { "unit": "decgbytes" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Memory Utilization %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "railway_service_memory_utilization * 100", "legendFormat": "{{service_name}}", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "grafana_prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Network Received (rate/5m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [{ "expr": "rate(railway_service_network_rx_gb_total[5m])", "legendFormat": "{{service_name}}", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "grafana_prometheus" },
      "fieldConfig": { "defaults": { "unit": "decgbytes" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Network Transmitted (rate/5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [{ "expr": "rate(railway_service_network_tx_gb_total[5m])", "legendFormat": "{{service_name}}", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "grafana_prometheus" },
      "fieldConfig": { "defaults": { "unit": "decgbytes" } }
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Current CPU Utilization",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "targets": [{ "expr": "railway_service_cpu_utilization * 100", "legendFormat": "{{service_name}}", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "grafana_prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 60, "color": "yellow" }, { "value": 80, "color": "red" }] } } }
    },
    {
      "id": 8,
      "type": "gauge",
      "title": "Current Memory Utilization",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 },
      "targets": [{ "expr": "railway_service_memory_utilization * 100", "legendFormat": "{{service_name}}", "refId": "A" }],
      "datasource": { "type": "prometheus", "uid": "grafana_prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 60, "color": "yellow" }, { "value": 80, "color": "red" }] } } }
    }
  ],
  "schemaVersion": 39
}
